def count_evens(nums):
    return sum(1 for x in nums if x % 2 == 0)

def big_diff(nums):
    return max(nums) - min(nums)

def centered_average(nums):
  return (sum(nums) - min(nums) - max(nums)) // (len(nums) - 2)

def sum13(nums):
    total = 0
    i = 0
    while i < len(nums):
        if nums[i] == 13:
            i += 2
            continue
        total += nums[i]
        i += 1
    return total

